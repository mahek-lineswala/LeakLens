# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration (Standard PostgreSQL URL)
DATABASE_URL="postgresql://username:password@localhost:5432/leaklens?schema=public"

# Authentication Secrets
JWT_ACCESS_SECRET="your_jwt_access_token_secret_minimum_32_characters"
JWT_REFRESH_SECRET="your_jwt_refresh_token_secret_minimum_32_characters"

# CORS configuration
# You can provide multiple origins separated by commas.
CORS_ORIGIN="http://localhost:5173"

# Cloudinary configuration (Phase 5)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AI provider selection
AI_PROVIDER="gemini"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
